@push('scripts')
    <script src="{{ asset('assets/dashbaord/vendors/js/pickers/bootstrap-datepicker/bootstrap-datepicker.min.js') }}">
    </script>
    <script src="{{ asset('assets/dashbaord/js/datepicker-initializer.js') }}"></script>
    <script src="{{ asset('assets/dashbaord/js/generic-select2.js') }}"></script>
    <script>
        $(document).ready(function() {
            let remainingAmount = 0;
            const currentChequeId = "{{ $payment->cheque_id }}";

            // Initialize Standard Select2 (for non-autocomplete)
            $('.js-select2:not(.select2-autocomplete)').select2({
                width: '100%',
                dir: $('html').attr('data-textdirection') || 'ltr'
            });

            let isInitialLoad = true;

            // Contract Selection Logic -> Fetch Balance & Filter Cheques
            $('.js-contract-select').on('change', function() {
                const contractId = $(this).val();

                // If user manually changes contract, reset and Disable fields below
                if (!isInitialLoad) {
                    $('#amount, .js-method-select, .js-cheque-select, #payment_date, #status, #reference_number, #notes')
                        .val('').prop('disabled', true);
                    $('.js-method-select').val('cash').trigger('change');
                    $('.js-cheque-select').empty().append(
                        '<option value="">{!! __('cheques.select_cheque') !!}</option>').trigger('change');
                    $('#status').val('paid').trigger('change');
                    $('.js-balance-warning').addClass('d-none');
                    $('.error-text').text(''); // Clear all validation errors
                    $('.form-control').removeClass('is-invalid');
                }

                if (!contractId) {
                    $('.js-balance-wrapper').slideUp(200);
                    return;
                }

                // AJAX to get contract details
                $.ajax({
                    url: "{!! route('dashboard.payments.contract-details', '') !!}/" + contractId +
                        "?payment_id={{ $payment->id }}",
                    type: "GET",
                    success: function(response) {
                        if (response.success) {
                            remainingAmount = response.data.remaining;

                            // In Edit Mode, we might want to add the current payment amount back to remaining for validation
                            const currentPaymentAmount = parseFloat(
                                "{{ $payment->amount }}") || 0;
                            const validationRemaining = remainingAmount + currentPaymentAmount;

                            // Update Balance Info
                            $('.js-total-amount').val(parseFloat(response.data.total_amount)
                                .toLocaleString(undefined, {
                                    minimumFractionDigits: 0,
                                    maximumFractionDigits: 0
                                }));
                            $('.js-paid-amount').val(parseFloat(response.data.total_paid)
                                .toLocaleString(undefined, {
                                    minimumFractionDigits: 0,
                                    maximumFractionDigits: 0
                                }));
                            $('.js-remaining-amount').val(parseFloat(remainingAmount)
                                .toLocaleString(undefined, {
                                    minimumFractionDigits: 0,
                                    maximumFractionDigits: 0
                                }));
                            const availableCheques = parseFloat(response.data
                                .pending_cheques_total || 0);
                            const originalCheques = parseFloat(response.data
                                .pending_cheques_original_total || 0);
                            $('.js-pending-cheques-total').val(
                                availableCheques.toLocaleString(undefined, {
                                    minimumFractionDigits: 0,
                                    maximumFractionDigits: 0
                                }) + ' / ' +
                                originalCheques.toLocaleString(undefined, {
                                    minimumFractionDigits: 0,
                                    maximumFractionDigits: 0
                                })
                            );
                            $('.js-pending-cheques-count').text(
                                `(${response.data.pending_cheques_count || 0})`);

                            // Set hidden customer ID
                            $('#customer_id_hidden').val(response.data.customer_id);

                            // Slide down if hidden
                            if ($('.js-balance-wrapper').is(':hidden')) {
                                $('.js-balance-wrapper').slideDown(250);
                            }
                            $('#amount, .js-method-select, .js-cheque-select, #payment_date, #status, #reference_number, #notes')
                                .prop('disabled', false);

                            // Filter Cheques
                            const chequeSelect = $('.js-cheque-select');
                            chequeSelect.empty().append(
                                '<option value="">{!! __('cheques.select_cheque') !!}</option>');

                            response.data.cheques.forEach(function(cheque) {
                                const selected = (cheque.id == currentChequeId) ?
                                    'selected' : '';
                                chequeSelect.append(
                                    `<option value="${cheque.id}"
                                     data-amount="${cheque.amount}"
                                     data-used="${cheque.used_amount}"
                                     data-remaining="${cheque.remaining_amount}"
                                     data-bank="${cheque.bank_name}"
                                     data-owner="${cheque.owner_name}"
                                     data-issue="${cheque.issue_date}"
                                     data-due="${cheque.due_date}"
                                     ${selected}>${cheque.cheque_number} - ${cheque.bank_name} (${parseFloat(cheque.remaining_amount).toLocaleString(undefined, {minimumFractionDigits: 0, maximumFractionDigits: 0})} / ${parseFloat(cheque.amount).toLocaleString(undefined, {minimumFractionDigits: 0, maximumFractionDigits: 0})})</option>`
                                    );
                            });
                            chequeSelect.trigger('change.select2'); // update select2 visual
                            chequeSelect.trigger(
                            'change'); // trigger our custom change logic to show card

                            // Reset initial load flag after everything is populated
                            setTimeout(() => {
                                isInitialLoad = false;
                            }, 100);
                        }
                    }
                });
            });

            // Trigger initial load for Edit Mode
            if ($('.js-contract-select').val()) {
                $('.js-contract-select').trigger('change');
            } else {
                isInitialLoad = false;
            }

            // Method Change Logic -> Auto Status & Amount Readonly state
            $('.js-method-select').on('change', function() {
                const method = $(this).val();
                const wrapper = $('.js-cheque-wrapper');
                const statusSelect = $('#status');
                const amountInput = $('#amount');

                if (!isInitialLoad) {
                    amountInput.val('').trigger('keyup');
                }

                if (method === 'cheque') {
                    wrapper.slideDown(250);
                    statusSelect.val('pending').trigger('change');
                    // In "Tank" approach, amount is editable
                    amountInput.prop('readonly', false).removeClass('bg-light');
                } else {
                    wrapper.slideUp(250);
                    $('.js-cheque-info-container').slideUp(250).empty();
                    amountInput.prop('readonly', false).removeClass('bg-light');

                    if (!isInitialLoad) {
                        $('#cheque_id').val('').trigger('change');
                        if (method === 'cash' || method === 'online') {
                            statusSelect.val('paid').trigger('change');
                        }
                    }
                }
            });

            // Cheque Selection Logic -> Update Info
            $('.js-cheque-select').on('change', function() {
                const option = $(this).find(':selected');
                const infoContainer = $('.js-cheque-info-container');
                const method = $('.js-method-select').val();

                if (!$(this).val() || method !== 'cheque') {
                    infoContainer.slideUp(250, function() {
                        $(this).empty();
                    });
                    return;
                }

                const original = parseFloat(option.data('amount') || 0);
                const used = parseFloat(option.data('used') || 0);
                const remaining = parseFloat(option.data('remaining') || 0);

                // In edit mode, the "remaining" from backend already considers this payment's current amount as "used".
                const isCurrentCheque = (option.val() == "{{ $payment->cheque_id }}");
                const currentPaymentValue = isCurrentCheque ? parseFloat("{{ $payment->amount }}") : 0;
                const effectiveRemaining = remaining + currentPaymentValue;

                const infoHtml = `
                    <div class="row mt-5">
                        <div class="col-md-4 mb-1">
                            <div class="premium-form-group">
                                <label class="premium-label text-uppercase text-muted font-weight-bold small">{!! __('payments.cheque_original_amount') !!}</label>
                                <div class="premium-input-wrapper">
                                    <input type="text" class="form-control premium-input bg-light font-weight-bold text-dark" value="${original.toLocaleString(undefined, {minimumFractionDigits: 0, maximumFractionDigits: 0})}" readonly>
                                    <i class="fas fa-money-check-alt text-danger"></i>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4 mb-1">
                            <div class="premium-form-group">
                                <label class="premium-label text-uppercase text-muted font-weight-bold small">{!! __('payments.cheque_used_amount') !!}</label>
                                <div class="premium-input-wrapper">
                                    <input type="text" class="form-control premium-input bg-light font-weight-bold text-danger" value="${(used - currentPaymentValue).toLocaleString(undefined, {minimumFractionDigits: 0, maximumFractionDigits: 0})}" readonly>
                                    <i class="fas fa-minus-circle text-danger"></i>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4 mb-1">
                            <div class="premium-form-group">
                                <label class="premium-label text-uppercase text-muted font-weight-bold small">{!! __('payments.cheque_remaining_amount') !!} ({!! __('general.available') !!} / {!! __('general.all') !!})</label>
                                <div class="premium-input-wrapper">
                                    <input type="text" class="form-control premium-input bg-light font-weight-bold text-success" value="${effectiveRemaining.toLocaleString(undefined, {minimumFractionDigits: 0, maximumFractionDigits: 0})} / ${original.toLocaleString(undefined, {minimumFractionDigits: 0, maximumFractionDigits: 0})}" readonly>
                                    <i class="fas fa-check-circle text-danger"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                `;

                infoContainer.html(infoHtml);
                if (infoContainer.is(':hidden')) {
                    infoContainer.slideDown(250);
                }

                if (!isInitialLoad) {
                    $('#amount').val(effectiveRemaining).trigger('keyup');
                }
            });

            // Real-time Amount Validation
            $('#amount').on('keyup change', function() {
                const amount = parseFloat($(this).val()) || 0;
                const method = $('.js-method-select').val();
                let hasError = false;

                // 1. Contract Balance Validation
                const currentPaymentAmount = parseFloat("{{ $payment->amount }}") || 0;
                const validationRemaining = remainingAmount + currentPaymentAmount;

                if (amount > validationRemaining) {
                    const formattedRem = validationRemaining.toLocaleString(undefined, {
                        minimumFractionDigits: 2
                    });
                    const msg = "{!! __('payments.amount_exceeds_remaining') !!} (" + formattedRem + ")";
                    $('.js-warning-text').text(msg);
                    $('.js-balance-warning').removeClass('d-none');
                    $(this).addClass('is-invalid');
                    hasError = true;
                } else {
                    $('.js-balance-warning').addClass('d-none');
                    $(this).removeClass('is-invalid');
                }

                // 2. Cheque Balance Validation
                if (method === 'cheque') {
                    const option = $('.js-cheque-select').find(':selected');
                    const remaining = parseFloat(option.data('remaining') || 0);
                    const isCurrentCheque = (option.val() == "{{ $payment->cheque_id }}");
                    const currentPaymentValue = isCurrentCheque ? parseFloat("{{ $payment->amount }}") : 0;
                    const effectiveRemaining = remaining + currentPaymentValue;

                    if (amount > effectiveRemaining) {
                        $('.js-cheque-warning').removeClass('d-none');
                        $(this).addClass('is-invalid');
                        hasError = true;
                    } else {
                        $('.js-cheque-warning').addClass('d-none');
                        if (amount <= validationRemaining) {
                            $(this).removeClass('is-invalid');
                        }
                    }
                } else {
                    $('.js-cheque-warning').addClass('d-none');
                }

                $('#saveBtn').prop('disabled', hasError);
            });


        });
    </script>
@endpush
