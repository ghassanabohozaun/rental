.cheque-status-lg {
    font-size: 14px !important;
    font-weight: bold !important;
}
.cheque-num-badge-sm {
    font-size: 10px !important;
}
.icon-size-16 { font-size: 16px !important; pointer-events: none; }
.icon-size-22 { font-size: 22px !important; pointer-events: none; }
.icon-size-24 { font-size: 24px !important; pointer-events: none; }
.font-11 { font-size: 11px !important; }

/* Cheque Info Card Container (Create/Edit) */
.cheque-info-card-container {
    display: none;
    border-top: 1px dashed rgb(228, 230, 239);
    border-bottom: 1px dashed rgb(228, 230, 239);
    padding-top: 15px;
    padding-bottom: 15px;
    margin-top: 8px;
    margin-bottom: 15px;
}

/* Cheques Table Progress Bar */
.cheque-table-progress-thin {
    height: 4px !important;
    background-color: #f0f0f0;
    margin-top: 2px;
}

/* Cheques Table Availability Text Container */
.cheque-table-available-container {
    margin-top: -2px;
}

/* Cheques Table Availability Text */
.cheque-table-available-text {
    font-size: 0.75rem !important;
    white-space: nowrap;
}

/* Cheque Wrapper */
.cheque-wrapper-hidden {
    display: none;
}

/* Segmented Tab Control - Compact Style */
.premium-segmented-control {
    display: inline-flex;
    background: #f4f5f8;
    border-radius: 8px;
    padding: 4px;
    gap: 4px;
}

.premium-tab-btn {
    padding: 6px 16px;
    font-size: 13px;
    font-weight: 600;
    border: none;
    border-radius: 6px;
    background: transparent;
    color: #6e7491;
    cursor: pointer;
    transition: all 0.2s ease;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    white-space: nowrap;
}

.premium-tab-btn i {
    font-size: 12px;
}

.premium-tab-btn.active {
    background: #4361ee;
    color: #fff;
    box-shadow: 0 2px 8px rgba(67, 97, 238, 0.3);
}

.premium-tab-btn:hover:not(.active) {
    background: #e8eaf6;
    color: #4361ee;
}
